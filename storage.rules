// ============================================================
// Firebase Storage Security Rules — ProStrike Football Academy
// Controls who can upload/download files (images, documents)
// Deploy: firebase deploy --only storage
// ============================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ============ GALLERY IMAGES ============
    match /gallery/{fileName} {
      // Anyone can view gallery images (public)
      allow read: if true;
      
      // Only admins can upload/delete gallery images
      allow write: if request.auth != null && 
        request.auth.token.admin == true &&
        // Restrict to image types only
        request.resource.contentType.matches('image/.*') &&
        // Max file size: 10MB
        request.resource.size < 10 * 1024 * 1024;
    }
    
    // ============ USER PROFILE PHOTOS ============
    match /profiles/{userId}/{fileName} {
      // Users can view any profile photo
      allow read: if true;
      
      // Users can only upload their own profile photo
      allow write: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.size < 5 * 1024 * 1024;  // Max 5MB
    }
    
    // ============ REGISTRATION DOCUMENTS ============
    match /registrations/{userId}/{fileName} {
      // Users can only access their own documents
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Users can upload registration documents
      allow write: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024;  // Max 10MB
    }
    
    // ============ DENY ALL OTHER PATHS ============
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
